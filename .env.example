ESLINT_NO_DEV_ERRORS=true

# Auth toggle — use `make auth_enable` / `make auth_disable` to switch.
DEVELOPMENT_ONLY_REQUIRE_AUTH=false

# Optional service tokens — leave empty to disable the feature in development.
SLACK_OAUTH_BOT_TOKEN=

# Optional Cartography credentials — only needed by the manual Cartography
# profile or scheduled sync worker for the corresponding enabled modules.
# CARTOGRAPHY_GITHUB_TOKEN is a base64-encoded JSON config, not a bare PAT — see
# docs/root/install/quickstart.md ("Loading GitHub data") for how to build it.
CARTOGRAPHY_GITHUB_TOKEN=
AIRBYTE_CLIENT_SECRET=
CARTOGRAPHY_ANTHROPIC_API_KEY=
AZURE_CLIENT_SECRET=
MICROSOFT_CLIENT_SECRET=
CLOUDFLARE_TOKEN=
NIST_NVD_TOKEN=
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
DATABRICKS_TOKEN=
DATABRICKS_CLIENT_SECRET=
DATABRICKS_ACCOUNT_CLIENT_SECRET=
DIGITALOCEAN_TOKEN=
GITLAB_TOKEN=
GOOGLEWORKSPACE_GOOGLE_APPLICATION_CREDENTIALS=
GSUITE_GOOGLE_APPLICATION_CREDENTIALS=
JAMF_PASSWORD=
JUMPCLOUD_API_KEY=
KANDJI_TOKEN=
KEYCLOAK_CLIENT_SECRET=
LASTPASS_CID=
LASTPASS_PROVHASH=
BIGFIX_PASSWORD=
DUO_API_KEY=
DUO_API_SECRET=
WORKDAY_API_PASSWORD=
CARTOGRAPHY_OPENAI_API_KEY=
PAGERDUTY_API_KEY=
OKTA_API_KEY=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_PRIVATE_KEY=
SCALEWAY_SECRET_KEY=
SEMGREP_APP_TOKEN=
SENTRY_TOKEN=
SENTINELONE_API_TOKEN=
SLACK_TOKEN=
SNIPEIT_TOKEN=
SOCKETDEV_TOKEN=
SPACELIFT_API_TOKEN=
SPACELIFT_API_KEY_ID=
SPACELIFT_API_KEY_SECRET=
SUBIMAGE_CLIENT_ID=
SUBIMAGE_CLIENT_SECRET=
TAILSCALE_TOKEN=
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=
VERCEL_TOKEN=
CIRCLECI_TOKEN=
WORKOS_API_KEY=

# APOC plugin toggle — use `make apoc_enable` / `make apoc_disable` to switch.
# When enabled, Neo4j downloads the matching APOC version on first start (requires internet).
NEO4J_PLUGINS=

# Neo4j live-version testing — use `make neo4j_current` / `make neo4j_latest`.
# `neo4j_latest` enables docker-compose.neo4j-latest.yml, which uses a separate
# neo4j_latest_data volume so the 5.26 development database is not upgraded.
COMPOSE_FILE=docker-compose.yml
NEO4J_LATEST_IMAGE_TAG=2026.04.0

# Neo4j notification severity (WARNING, INFORMATION, OFF).
# Set to OFF to suppress schema warnings when the database is not fully populated.
# NEO4J_NOTIFICATIONS_MIN_SEVERITY=WARNING

# Extra procedures the Cypher query validator permits, beyond the built-in
# read-only schema procedures allowed by default. Comma-separated; each entry
# is an exact procedure name (apoc.meta.stats) or a namespace prefix ending in
# a dot (apoc., gds.). This does not permit dangerous function namespaces such
# as apoc.cypher.* or gds.*. Empty by default.
# QUERY_VALIDATOR_ALLOWED_PROCEDURES=

# Timeout settings (all values in seconds). Defaults shown.
# NEO4J_CONNECTION_TIMEOUT=10    # TCP connection to Neo4j
# NEO4J_QUERY_TIMEOUT=30         # server-side Neo4j transaction timeout
# API_REQUEST_TIMEOUT=60         # FastAPI request timeout (returns 504 on expiry)
# JWKS_FETCH_TIMEOUT=10          # JWKS endpoint HTTP request
# AWS_CONNECT_TIMEOUT=5          # boto3 TCP connection (DynamoDB, SQS)
# AWS_READ_TIMEOUT=30            # boto3 read operation (DynamoDB, SQS)
# SQL_STATEMENT_TIMEOUT=30       # asyncpg/PostgreSQL statement timeout
# SLACK_TIMEOUT=30               # Slack SDK API call timeout

# Report storage backend. Supported: dynamodb (default), sqlmodel.
REPORT_STORE_BACKEND=dynamodb

# SQLModel database URL and credentials (used when REPORT_STORE_BACKEND=sqlmodel).
# Keep credentials out of SQL_DATABASE_URL so only SQL_DATABASE_PASSWORD needs
# secret-manager handling. Credential-bearing URLs remain supported.
# Any SQLAlchemy-compatible URL: postgresql://, sqlite:///, etc.
# In development the docker-compose.yml pre-configures the postgres container URL.
# SQL_DATABASE_URL=postgresql://postgres:5432/seizu
# SQL_DATABASE_USER=seizu
# SQL_DATABASE_PASSWORD=

# DynamoDB report config storage.
# In development these are set automatically via docker-compose.yml.
# Override here only if you need non-default values (e.g. a real AWS table).
# DYNAMODB_TABLE_NAME=seizu-reports
# DYNAMODB_REGION=us-east-1
# DYNAMODB_ENDPOINT_URL=
# DYNAMODB_CREATE_TABLE=false
# SNOWFLAKE_MACHINE_ID=1

# Temporal-backed configurable workflows and code-defined workflow activities.
# Address of the Temporal frontend (gRPC). docker-compose sets temporal:7233.
# TEMPORAL_ADDRESS=localhost:7233
# TEMPORAL_NAMESPACE=default
# Task queue shared by schedules, configurable workflows, and the worker.
# TEMPORAL_TASK_QUEUE=seizu-workflows
# Set false to disable the worker process without removing the service.
# TEMPORAL_WORKER_ENABLED=true
# Configurable workflow query/activity limits and reconciliation intervals.
# WORKFLOW_QUERY_MAX_ROWS=200
# Maximum serialized bytes retained for an activity output or forwarded input.
# WORKFLOW_RESULT_MAX_BYTES=1000000
# WORKFLOW_WATCH_POLL_SECONDS=20
# WORKFLOW_RECONCILE_SECONDS=30
# Comma-separated activity modules. SCHEDULED_QUERY_MODULES remains a
# compatibility alias for one release.
# WORKFLOW_ACTIVITY_MODULES=reporting.scheduled_query_modules.sqs,reporting.scheduled_query_modules.slack,reporting.scheduled_query_modules.statsd
# Cap on query result rows forwarded into a code-defined workflow.
# TEMPORAL_WORKFLOW_MAX_RESULT_ROWS=200
# Allowlist of code-defined workflows exposed as top-level activity types
# (comma-separated). Empty → all registered workflows,
# e.g. enable assessment but not remediation: TEMPORAL_ENABLED_WORKFLOWS=cve_repo_report
# TEMPORAL_ENABLED_WORKFLOWS=
# Per-repository AI chat activity timeout in seconds.
# TEMPORAL_CHAT_ACTIVITY_TIMEOUT_SECONDS=600

# Cartography syncs (cartography_sync workflow): runs cartography intel-module
# syncs as a staged pipeline on the dedicated seizu-cartography-worker service
# (Dockerfile.cartography). Module credentials come from the cartography token
# vars above. The sync worker itself reads TEMPORAL_ADDRESS/TEMPORAL_NAMESPACE
# plus CARTOGRAPHY_NEO4J_URI (set in docker-compose.yml; and optionally
# CARTOGRAPHY_NEO4J_USER + NEO4J_PASSWORD when Neo4j auth is on).
# Task queue the sync worker polls (workflow activities are dispatched there).
# CARTOGRAPHY_TASK_QUEUE=seizu-cartography
# Allowlist of registry modules scheduled syncs may run (comma-separated;
# empty → all modules supported by the pinned Cartography release). Enforced
# at save time, at dispatch, and again by the credential-bearing sync worker.
# CARTOGRAPHY_ENABLED_MODULES=
# Default per-module-run timeout in seconds (overridable per schedule).
# CARTOGRAPHY_MODULE_TIMEOUT_SECONDS=3600
# How long a module run may wait (seconds) for an overlapping run of the same
# module to finish (serialized via Temporal workflow-ID uniqueness; concurrent
# same-module syncs race on cartography's update tags and can delete each
# other's data).
# CARTOGRAPHY_MODULE_WAIT_SECONDS=3600
# Temporal retry attempts per module run (config errors never retry).
# CARTOGRAPHY_SYNC_RETRY_ATTEMPTS=2

# CVE dependency remediation (cve_dependency_remediation workflow): a
# coding-agent CLI in an ephemeral sandbox upgrades the vulnerable dependency
# (with compatibility code changes), runs the tests, and opens a PR.
# Credentials are phase-isolated: the coding agent never runs with the GitHub
# token in its environment. No enable flag and no per-user permission —
# configured = enabled; reachable only via admin-managed scheduled queries,
# so disable the query (or remove this config) to turn it off.
# Coding-agent CLI + credentials (shared SANDBOX_AGENT_* family; the remediation
# workflow is one consumer):
# SANDBOX_AGENT_PROVIDER=claude   # "claude" (Claude Code), "codex", or "opencode"
# E2B template for the run. Empty → the provider's official prebuilt template
# ("claude"/"codex"/"opencode" — CLI preinstalled, no per-run npm install);
# "none" → base image (installs the CLI itself). Ignored on self-hosted backends.
# SANDBOX_AGENT_TEMPLATE=
# For opencode, SANDBOX_AGENT_MODEL is required as "provider/model" and
# selects the provider, e.g. deepseek/deepseek-v4-pro (uses DEEPSEEK_API_KEY,
# the same key the chat assistant uses).
# SANDBOX_AGENT_MODEL=
# SANDBOX_AGENT_API_KEY=          # Empty → falls back to the model provider's global *_API_KEY
# Command whose stdout becomes a per-run agent API key — use to mint
# short-lived credentials from a broker instead of a long-lived key.
# SANDBOX_AGENT_API_KEY_COMMAND=
# LLM gateway/proxy base URL exported to the agent (ANTHROPIC_BASE_URL /
# OPENAI_BASE_URL); pair with the key command for short-lived gateway keys.
# SANDBOX_AGENT_BASE_URL=
# Ephemeral credential-proxy sandbox: run a short-lived LiteLLM proxy in its own
# sandbox holding the real provider key, and hand the agent sandbox only a
# budget-capped virtual key. The real key never enters the untrusted agent VM;
# the virtual key dies when the proxy sandbox is torn down. All providers
# (opencode needs SANDBOX_AGENT_MODEL); mutually exclusive with SANDBOX_AGENT_BASE_URL.
# SANDBOX_AGENT_CREDENTIAL_PROXY_ENABLED=false
# SANDBOX_AGENT_CREDENTIAL_PROXY_MAX_BUDGET=5   # USD cap on the per-run virtual key
# REMEDIATION_TIMEOUT_SECONDS=1800
# Post-push CI watch: the workflow polls the PR's checks; relevant failures get
# a coding-agent fix run pushed to the same branch, irrelevant ones an
# explanatory PR comment. Checks stuck in queued are ignored.
# REMEDIATION_CI_MAX_WAIT_SECONDS=3600   # total wait for checks to settle; 0 disables the watch
# REMEDIATION_CI_POLL_SECONDS=120
# REMEDIATION_CI_QUEUED_STUCK_SECONDS=1800  # queued this long without starting → ignored
# REMEDIATION_CI_FIX_MAX_ATTEMPTS=1      # coding-agent fix runs per PR; 0 → watch/record only
# Pinned gh (GitHub CLI) version installed in the sandbox when not already present.
# REMEDIATION_GH_VERSION=2.62.0
# Expected SHA-256 of the pinned gh linux_amd64 tarball for an independent
# supply-chain pin (empty → verify against the release's own checksums).
# REMEDIATION_GH_SHA256=
# REMEDIATION_GITHUB_HOST=github.com  # or a GitHub Enterprise Server hostname
# GitHub token for clone/push/PR and the worker-side CI watch; the coding
# agent never sees it. Direct mode: fine-grained PAT on the target repos
# (contents + pull requests write, issues write, checks + commit statuses
# read). Fork mode: classic PAT on a machine account. See the docs section
# "GitHub token setup" (docs/root/install/temporal-workflows.md).
# REMEDIATION_GITHUB_TOKEN=
# Fork mode: push the work branch to a bot-owned fork (created on demand) and
# open cross-repo PRs. NOTE: fine-grained PATs are single-resource-owner and
# can't span the bot's forks + another owner's targets (fork creation also
# needs Administration:write) — use a classic PAT on the bot account
# (public_repo, or repo for private targets) or a GitHub App token.
# REMEDIATION_USE_FORK=false
# REMEDIATION_FORK_ORG=       # org owning the forks; empty → the token user's account
# REMEDIATION_GIT_USER=seizu-remediation-bot
# REMEDIATION_GIT_EMAIL=seizu-remediation@localhost

# Scheduled chats (recurring headless agent runs managed from the chat UI;
# creating/editing them requires the chat:schedule permission).
# CHAT_SCHEDULES_ENABLED=true
# How often (seconds) the scheduled chats worker polls for due schedules.
# CHAT_SCHEDULES_POLL_SECONDS=20
# Timeout in seconds for one scheduled headless agent session.
# CHAT_SCHEDULE_TIMEOUT_SECONDS=600

# Master switch for the chat assistant feature (routes + UI). Default false.
# CHAT_ENABLED=false
#
# LLM provider for chat. Default "mock" keeps local dev keyless and deterministic.
# Any other value routes through LiteLLM, so the provider/model surface is whatever
# LiteLLM supports rather than a fixed list. Legacy values (openai, anthropic,
# gemini, deepseek) still work and namespace a bare CHAT_LLM_MODEL; otherwise leave
# this at "litellm" and set a fully-qualified CHAT_LLM_MODEL.
# CHAT_LLM_PROVIDER=mock
#
# CHAT_LLM_MODEL is REQUIRED whenever CHAT_LLM_PROVIDER is not "mock". Set it to a
# LiteLLM model identifier — there is no default, so a missing value fails fast at
# startup. Prefer a provider-namespaced string; pick the current model rather than
# copying these examples blindly:
#   openai     e.g. openai/gpt-4o                  (https://platform.openai.com/docs/models)
#   anthropic  e.g. anthropic/claude-sonnet-4-6    (https://docs.anthropic.com/en/docs/about-claude/models)
#   gemini     e.g. gemini/gemini-2.5-flash        (https://ai.google.dev/gemini-api/docs/models)
#   deepseek   e.g. deepseek/deepseek-reasoner     (https://api-docs.deepseek.com/quick_start/pricing)
# See LiteLLM's provider list for the full set: https://docs.litellm.ai/docs/providers
# CHAT_LLM_MODEL=
# CHAT_LLM_API_KEY=
# Point at a self-hosted LiteLLM proxy or other OpenAI-compatible gateway (api_base):
# CHAT_LLM_BASE_URL=
# CHAT_LLM_TEMPERATURE=0.2
# CHAT_LLM_MAX_TOKENS=4096
# CHAT_LLM_TIMEOUT_SECONDS=60
# CHAT_LLM_MAX_RETRIES=2
# Auto-continue answers cut off by the output-token limit, stitched seamlessly.
# Set CHAT_LLM_MAX_CONTINUATIONS=0 to disable (keep the manual continue button).
# CHAT_LLM_MAX_CONTINUATIONS=2
# CHAT_LLM_MAX_RESPONSE_CHARS=60000
# CHAT_LLM_CONTEXT_MAX_MESSAGES=80
# CHAT_LLM_CONTEXT_MAX_CHARS=120000
# CHAT_LLM_SYSTEM_PROMPT=
# CHAT_LLM_PROGRESSIVE_DISCLOSURE=true
# CHAT_LLM_MAX_AUTO_ACTIONS=12
# CHAT_LLM_MAX_PARALLEL_TOOL_CALLS=4
# Plan -> dispatch -> verify orchestration for complex chat requests (on by
# default; set false to use the single-agent path for interactive turns).
# CHAT_ORCHESTRATOR_ENABLED=true
# CHAT_ORCHESTRATOR_MAX_STEPS=8
# CHAT_ORCHESTRATOR_PLANNER_MAX_TOKENS=4096
# CHAT_ORCHESTRATOR_MAX_ITERATIONS=3
# CHAT_ORCHESTRATOR_MAX_PARALLEL=3
# Compatibility per-worker loop guard when all shared budget dimensions are
# disabled. Normal interactive and automated plans use the run-level budget.
# CHAT_ORCHESTRATOR_WORKER_MAX_ACTIONS=24
# Per-turn budget shared by interactive and automated chat. Cost budgeting is
# disabled by default because private gateways/custom models may not have known
# pricing; token and call limits still apply.
# CHAT_RUN_TOKEN_BUDGET=120000
# CHAT_RUN_COST_BUDGET_USD=0
# CHAT_RUN_RESERVE_PERCENT=20
# CHAT_RUN_SOFT_LIMIT_PERCENT=75
# CHAT_RUN_MAX_LLM_CALLS=64
# Optional role-specific models; empty values inherit CHAT_LLM_MODEL.
# CHAT_LLM_PLANNER_MODEL=
# CHAT_LLM_WORKER_MODEL=
# CHAT_LLM_VERIFIER_MODEL=
# CHAT_LLM_SYNTHESIZER_MODEL=
# CHAT_LLM_ECONOMY_MODEL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=

# LangGraph chat checkpoint storage.
# Supported backends: dynamodb (default), postgres. The PostgreSQL checkpointer
# requires PostgreSQL even when the report store uses another SQL database.
# The Makefile sqlmodel_enable/sqlmodel_disable targets switch both stores.
# CHAT_CHECKPOINT_BACKEND=dynamodb
# URL and credentials default to the corresponding SQL_DATABASE_* settings.
# Set the checkpoint-specific values only when it uses a different database or
# credentials. Credential-bearing URLs remain supported.
# Local Compose defaults to a separately provisioned `seizu-chat-checkpoints`
# database on the same PostgreSQL server.
# CHAT_CHECKPOINT_DATABASE_URL=postgresql://postgres:5432/seizu-chat-checkpoints
# CHAT_CHECKPOINT_DATABASE_USER=
# CHAT_CHECKPOINT_DATABASE_PASSWORD=
# CHAT_CHECKPOINT_DATABASE_POOL_MIN_SIZE=1
# CHAT_CHECKPOINT_DATABASE_POOL_MAX_SIZE=10
#
# DynamoDB-only settings. In development docker-compose.yml points these at
# DynamoDB Local and MinIO.
# CHAT_CHECKPOINT_TABLE_NAME=seizu-chat-checkpoints
# CHAT_CHECKPOINT_CREATE_TABLE=false
# CHAT_CHECKPOINT_TTL_SECONDS=0
# CHAT_CHECKPOINT_ENABLE_COMPRESSION=true
# CHAT_CHECKPOINT_S3_BUCKET=
# CHAT_CHECKPOINT_S3_ENDPOINT_URL=
# CHAT_CHECKPOINT_S3_KEY_PREFIX=seizu/langgraph
# CHAT_MAX_PERSISTED_MESSAGES=200
# CHAT_HISTORY_LIMIT=100
# CHAT_TOOL_RESULT_MAX_ROWS=100
# CHAT_TOOL_RESULT_MAX_BYTES=200000

# RBAC settings.
# JWT claim that contains the user's Seizu role name.
# Configure your OIDC provider to embed the role directly as a claim (e.g. "seizu-admin").
# RBAC_ROLE_CLAIM=seizu_role
#
# Default role when the user's JWT has no RBAC_ROLE_CLAIM.
# Valid values: "seizu-viewer", "seizu-editor", "seizu-admin", or any user-defined role name.
# Set to "" to deny access to users without an explicit role claim.
# RBAC_DEFAULT_ROLE=seizu-viewer

# Shared secret used to sign report-query capability tokens.
# Generate a cryptographically random value with at least 32 bytes of entropy;
# 64 bytes is preferred. Encode as hex or base64 and keep it stable across
# restarts. If you use hex, 32 bytes = 64 characters and 64 bytes = 128
# characters. If you use base64, 32 bytes is typically 44 characters with
# padding. Rotate if exposed; rotation invalidates outstanding report tokens.
# REPORT_QUERY_SIGNING_SECRET=

# AES-256-GCM key used to encrypt the IDP refresh token in the browser
# session cookie. Must decode to exactly 32 bytes. Generate with:
#   python -c 'import base64,os;print(base64.b64encode(os.urandom(32)).decode())'
# Rotate if exposed; rotation forces all logged-in users to sign in again.
# SESSION_TOKEN_ENCRYPTION_KEY=

# Rolling lifetime of the session cookie (seconds). Default 18h. Each
# successful refresh re-issues the cookie with this Max-Age, capped at
# the IDP refresh token's absolute expiry recorded at login.
# SESSION_COOKIE_MAX_AGE_SECONDS=64800

# Override the session cookie name.
# SESSION_COOKIE_NAME=seizu_session

# Optional confidential-client settings for the BFF OAuth client. Public PKCE
# clients should keep the defaults. For confidential clients, set a secret and
# choose the IDP-supported auth method, usually client_secret_basic.
# OIDC_CLIENT_SECRET=
# OIDC_TOKEN_ENDPOINT_AUTH_METHOD=none
# OIDC_REVOCATION_ENDPOINT_AUTH_METHOD=none

# Whether to revoke the OIDC refresh token on logout.
# Failures are logged but never block the user's local logout.
# OIDC_REVOKE_REFRESH_TOKEN_ON_LOGOUT=true

# Absolute session upper bound (seconds) used only when the IDP's token
# response omits refresh_expires_in. Default: 30 days (Authentik's default).
# When the IDP advertises refresh_expires_in on a rotating refresh, the
# session's absolute cap is rolled forward to match.
# OIDC_REFRESH_TOKEN_FALLBACK_TTL_SECONDS=2592000

# Extra query parameters appended to the OIDC authorize request, as a
# comma-separated list of key=value pairs. Use for provider-specific knobs the
# standard scope can't express. Google, for instance, only issues a refresh
# token when the authorize request carries access_type=offline (and
# prompt=consent to re-issue one on repeat logins) instead of offline_access:
# OIDC_AUTHORIZE_EXTRA_PARAMS=access_type=offline,prompt=consent

# Enable RFC 7662 token introspection as a fallback when a Bearer token isn't a
# verifiable JWT. Required for IDPs that issue opaque (non-JWT) access tokens
# (e.g. Google, some Okta/Auth0 setups). Introspection authenticates with the
# client credentials, so it generally pairs with a confidential client.
# OIDC_ENABLE_TOKEN_INTROSPECTION=false
# Authlib client-auth method for the introspection endpoint. Defaults to
# OIDC_TOKEN_ENDPOINT_AUTH_METHOD.
# OIDC_INTROSPECTION_ENDPOINT_AUTH_METHOD=none

# How long (seconds) to cache the OIDC discovery document before re-fetching.
# A non-infinite TTL lets rotated endpoints/JWKS recover without a restart.
# OIDC_DISCOVERY_CACHE_TTL_SECONDS=3600

# Validate the ID token from the BFF code exchange (signature via the discovery
# JWKS, audience, issuer, and the login nonce). Secure by default; disable only
# for non-conformant providers whose ID token can't be verified server-side.
# OIDC_VALIDATE_ID_TOKEN=true

# MCP server at /api/v1/mcp. Disable to turn off the endpoint entirely.
# MCP_ENABLED=true

# Which built-in MCP tool groups to expose. User-defined toolsets are always available.
# Unset or empty: all groups enabled (default).
# "none": disable all built-in groups.
# Comma-separated list: only those groups (e.g. "graph,reports").
# Known groups: graph, reports, sandbox, scheduled_queries, skillsets, toolsets, roles.
# Note: sandbox is chat-only — it never appears on the MCP server endpoint regardless.
# MCP_ENABLED_BUILTINS=graph,reports,sandbox,scheduled_queries,skillsets,toolsets,roles

# Sandbox delegation (sandbox__delegate chat tool — chat-only, not on MCP endpoint).
# Enable to let the chat agent delegate code execution / file operations to an
# isolated E2B (https://e2b.dev) or OpenKruise Agents sandbox.
# SANDBOX_ENABLED=false
# SANDBOX_API_KEY=              # E2B API key; leave empty for self-hosted auth
# SANDBOX_DOMAIN=               # Sandbox hostname (empty → E2B cloud). For OpenKruise
#                               # Agents: set to your cluster ingress hostname.
# SANDBOX_ALLOW_INTERNET=false  # Allow sandboxes to make outbound internet connections.
#                               # Defaults to false (network-isolated). Enable only when
#                               # the task explicitly requires external network access.
# SANDBOX_TIMEOUT_SECONDS=120
# SANDBOX_MAX_OUTPUT_BYTES=50000
# SANDBOX_LLM_MODEL=            # Empty → inherits CHAT_LLM_MODEL

# OAuth 2.0 metadata for MCP clients (enables in-client auth, e.g. Claude Desktop).
# Set to your OIDC provider's authorization and token endpoints.
# Authentik example:
# MCP_OAUTH_AUTHORIZATION_ENDPOINT=https://authentik.example.com/application/o/seizu/authorize/
# MCP_OAUTH_TOKEN_ENDPOINT=https://authentik.example.com/application/o/token/
# MCP_OAUTH_ISSUER=https://authentik.example.com/application/o/seizu/
# (MCP_OAUTH_ISSUER defaults to JWT_ISSUER if unset)
# Public base URL of the MCP endpoint — required for RFC 9728 protected resource
# discovery and the WWW-Authenticate resource_metadata header.
# MCP_RESOURCE_URL=https://seizu.example.com/api/v1/mcp
# Maximum lifetime for mutating MCP/chat action approvals and denials.
# ACTION_CONFIRMATION_TTL_SECONDS=1800
# Optional public browser origin for confirmation URLs. Defaults to the origin
# derived from MCP_RESOURCE_URL when unset.
# SEIZU_PUBLIC_URL=https://seizu.example.com
# Internal authority URL used by the server for OIDC discovery. Defaults to
# OIDC_AUTHORITY; set this when the server cannot reach the public OIDC_AUTHORITY
# (e.g. environments with split internal/external hostnames).
# OIDC_INTERNAL_AUTHORITY=https://internal-idp.example.com/application/o/seizu/
# Override the dynamic client registration (RFC 7591) endpoint in OAuth metadata.
# When unset, Seizu serves its own built-in endpoint that returns OIDC_CLIENT_ID,
# which satisfies MCP clients (e.g. Claude Desktop) that require DCR support.
# MCP_OAUTH_REGISTRATION_ENDPOINT=
